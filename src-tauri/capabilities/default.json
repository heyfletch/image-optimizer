{
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "node",
          "cmd": "node",
          "args": true
        }
      ]
    },
    "shell:allow-stdin-write",
    "dialog:allow-open",
    "dialog:allow-save"
  ]
}
